{
  "name": "fanzai-client",
  "version": "0.1.0",
  "description": "饭仔 9Router 客户端 — 现代化 GUI 启动器",
  "main": "src/main/main.js",
  "author": "fanzai",
  "private": true,
  "scripts": {
    "dev": "electron . --dev",
    "pack:win:green": "electron-builder --win portable",
    "pack:mac:green": "electron-builder --mac zip",
    "pack:win:setup": "electron-builder --win nsis",
    "pack:mac:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.fanzai.client",
    "productName": "饭仔客户端",
    "directories": {
      "output": "runtime/electron-app"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "饭仔客户端.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "饭仔客户端-Setup.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "饭仔客户端-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "javascript-obfuscator": "^5.4.3"
  }
}
